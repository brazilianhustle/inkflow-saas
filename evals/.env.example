# ── Eval harness env ──
# Opção 1 (recomendado): secret permanente do Cloudflare. Nunca expira.
#   - Gere: openssl rand -hex 32
#   - Cadastre no CF: npx wrangler pages secret put EVAL_SECRET --project-name=inkflow-saas
#   - Cole o MESMO valor aqui abaixo.
EVAL_SECRET=

# Opção 2 (fallback): JWT do admin (lmf4200@gmail.com). EXPIRA em ~1h.
#   - Pega logando em https://inkflowbrasil.com/admin.html
#   - Clica em "Copiar JWT dev" e cola aqui.
ADMIN_BEARER=

# Tenant alvo dos testes (Betinho Betornera por padrão durante dev)
TENANT_ID=e773533e-8b48-4952-b59b-6bc078aa3ecd

# OpenAI key pra critic (gpt-4o como juiz cross-model)
OPENAI_API_KEY=

# Opcionais
BASE_URL=https://inkflowbrasil.com
MODEL_CRITIC=gpt-4o
TURN_DELAY_MS=500
