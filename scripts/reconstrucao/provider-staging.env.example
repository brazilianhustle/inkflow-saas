# Copie para ~/.inkflow-secrets/provider-staging.env e substitua apenas os valores.
# Use somente este formato: export NOME="valor"
# Nao coloque token, senha, API key, URL de webhook, numero real ou segredo bruto aqui.

export EVOLUTION_STAGING_SECRET_SOURCE="bitwarden_evolution_staging"
export TELEGRAM_STAGING_SECRET_SOURCE="bitwarden_telegram_staging"
export CLOUDFLARE_WORKER_STAGING_SECRET_SOURCE="cloudflare_worker_staging_bindings"
export EVOLUTION_STAGING_INSTANCE_LABEL="fake_staging_evolution_instance"
export TELEGRAM_STAGING_BOT_LABEL="fake_staging_telegram_bot"
export TELEGRAM_STAGING_CHAT_LABEL="fake_staging_telegram_chat"
