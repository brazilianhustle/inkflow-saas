# Slice Gate: <slice-id>
#
# Copiar para:
# docs/atendimento-premium/slice-gates/<slice-id>.env

SLICE_ID="<slice-id>"
SLICE_TITLE="<titulo humano do slice>"

# Corte minimo para ignorar PASS antigo que nao cobre o comportamento atual.
# Formato: YYYY-MM-DD HH:MM em UTC.
MIN_PASS_UTC="<YYYY-MM-DD HH:MM>"

# Um scenario por linha. O run_id em smoke-runs.md precisa seguir:
# scenario-<scenario-id>-...
REQUIRED_SCENARIOS=$'<scenario-http-radar>\n<scenario-whatsapp-real-final>'

# Scenario que valida a cadeia real quando aplicavel.
FINAL_REHEARSAL_SCENARIO="<scenario-whatsapp-real-final>"

# Artefatos minimos para considerar um PASS auditavel.
REQUIRED_ARTIFACTS=$'summary.md\npoll.json\ntranscript.md\njudgment.md'
