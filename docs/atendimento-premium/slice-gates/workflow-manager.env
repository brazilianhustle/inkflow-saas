# Slice Gate: workflow-manager
#
# Gate para a camada que valida saida de fase, preserva estado quando o Router
# nao permite mutacao e oficializa handoff humano como transicao segura.

SLICE_ID="workflow-manager"
SLICE_TITLE="Workflow Manager e transicoes de estado"

MIN_PASS_UTC="2026-05-25 20:55"

REQUIRED_SCENARIOS=$'cadastro-handoff-email-recusado\nwhatsapp-real-cadastro-handoff\nlateral-preco-generico\nwhatsapp-real-lateral-preco-generico\ncadastro-data-idade-nao-persiste\nwhatsapp-real-cadastro-data-idade-nao-persiste\ntattoo-cliente-irritado-handoff\nwhatsapp-real-tattoo-cliente-irritado-handoff\ntattoo-gatilho-tenant-handoff\nwhatsapp-real-tattoo-gatilho-tenant-handoff'
FINAL_REHEARSAL_SCENARIO="whatsapp-real-tattoo-cliente-irritado-handoff"

REQUIRED_ARTIFACTS=$'summary.md\npoll.json\ntranscript.md\njudgment.md\nagent-turn-logs.json\nscenario-agent-log-jq.txt'
