# Smoke Scenario: whatsapp-real-voice-policy-pure-greeting
#
# Wave 25 Micro-slice 1 definitivo via Evolution central.

SCENARIO_ID="whatsapp-real-voice-policy-pure-greeting"
SCENARIO_TITLE="WhatsApp real: saudacao pura sem apresentacao mecanica"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="oi"
EXPECTED_STATE="coletando_tattoo"

EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="^Oii, tudo bem\\.|Como posso te chamar\\?"
FORBIDDEN_BOT_REGEX="Me chamo|muito prazer|R\\$|[0-9]+ reais|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null'

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
