# Smoke Scenario: lateral-processo-tatuagem
#
# Objetivo:
# Validar que pergunta sobre processo recebe explicacao curta e retoma coleta.

SCENARIO_ID="lateral-processo-tatuagem"
SCENARIO_TITLE="Atendimento lateral: processo de tatuagem"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="como funciona pra fazer uma tattoo?"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="ideia|refer[eê]ncia|tatuador|avali|or[cç]amento"
FORBIDDEN_BOT_REGEX="sou uma ia|sistema|prompt|erro"
