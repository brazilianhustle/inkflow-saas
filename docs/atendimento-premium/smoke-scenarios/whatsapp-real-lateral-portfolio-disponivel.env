# Smoke Scenario: whatsapp-real-lateral-portfolio-disponivel
#
# Objetivo:
# Validar via WhatsApp real que pedido de portfolio com portfolio cadastrado
# responde sem URL manual, aciona o fluxo de portfolio e mantem estado seguro.

SCENARIO_ID="whatsapp-real-lateral-portfolio-disponivel"
SCENARIO_TITLE="WhatsApp real: portfolio disponivel sem URL manual"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="tem exemplos de fineline?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="mando|trabalhos|exemplos|refer"
FORBIDDEN_BOT_REGEX="https?://|www\\.|instagram\\.com|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_TAIL_REGEX="enviar-portfolio|portfolio"
FORBIDDEN_TAIL_REGEX="pipeline batch failed|unhandled|sendMedia falhou"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "tattoo" and .client_input_text == "tem exemplos de fineline?" and .context_metadata.tenant_context_layer == "tenant_context_manager" and .context_metadata.tenant_context_state == "tattoo" and .context_metadata.tenant_context_portfolio_disponivel == true and .context_metadata.tenant_context_estilos_aceitos_count == 2 and .context_metadata.tenant_context_uses_legacy_style_catalog == true)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
