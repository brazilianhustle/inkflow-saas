# Smoke Scenario: tattoo-pending-height-lateral
#
# Objetivo:
# Validar em HTTP multi-turn que uma resposta a altura pendente pode vir junto
# de uma pergunta lateral de tempo/sessoes sem perder a altura e sem repetir a
# pergunta de altura.

SCENARIO_ID="tattoo-pending-height-lateral"
SCENARIO_TITLE="Tattoo pending altura + lateral de tempo"
SCENARIO_TYPE="http_multiturn"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

STEP_COUNT="2"
STEP_WAIT_SECONDS="2"

MESSAGE_1="quero uma baleia fineline na barriga"
EXPECTED_STATE_1="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_1="medio"
EXPECTED_BOT_REGEX_1="qual tua altura|qual a tua altura|qual sua altura|altura"
FORBIDDEN_BOT_REGEX_1="parte do corpo|qual parte|foto do local|orc_"
EXPECTED_POLL_JQ_TRUE_1='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("baleia"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("barriga"; "i")) and ((.conversas[0].dados_coletados.altura_cm == null) or (.conversas[0].dados_coletados | has("altura_cm") | not))'

MESSAGE_2="tenho 1.70
quanto tempo demora?"
EXPECTED_STATE_2="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_2="medio"
EXPECTED_BOT_REGEX_2="tempo de sess[aã]o depende|tamanho|detalhe|local|foto"
FORBIDDEN_BOT_REGEX_2="qual tua altura|qual a tua altura|qual sua altura|parte do corpo|qual parte|qual estilo|que estilo|orc_"
EXPECTED_POLL_JQ_TRUE_2='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("baleia"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("barriga"; "i")) and .conversas[0].dados_coletados.altura_cm == 170'
