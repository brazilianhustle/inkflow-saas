# Smoke Scenario: cadastro-handoff-email-recusado
#
# Objetivo:
# Validar que cadastro completo via router, com email recusado e pergunta lateral
# de tempo, transiciona para aguardando_tatuador e gera orcid.

SCENARIO_ID="cadastro-handoff-email-recusado"
SCENARIO_TITLE="Cadastro completo com email recusado dispara handoff"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_cadastro_handoff_email_recusado"
CLEANUP_BEFORE="1"

MESSAGE=$'pode seguir sem email\nquanto tempo demora?'
EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="1"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="tempo de sess[aã]o|tatuador avaliar|retorno por aqui|valor"
FORBIDDEN_BOT_REGEX="Fechado|valor certinho|avaliar com calma|or[cç]amento liberado|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "workflow_manager" and (.client_input_text | contains("pode seguir sem email")) and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "cadastro" and .context_metadata.workflow_to_state == "aguardando_tatuador" and .context_metadata.workflow_transition_allowed == true and .context_metadata.workflow_reason == "cadastro_and_tattoo_complete" and .context_metadata.workflow_handoff_package_required == true and .context_metadata.workflow_handoff_package_version == "handoff_package_v1" and (.context_metadata.workflow_handoff_package_trace_id | startswith("hp_")))'
