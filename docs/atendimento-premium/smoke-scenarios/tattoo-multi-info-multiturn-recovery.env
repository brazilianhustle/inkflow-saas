# Smoke Scenario: tattoo-multi-info-multiturn-recovery
#
# Objetivo:
# Validar em HTTP multi-turn que o Router recupera campos adicionais quando
# o cliente responde uma pergunta pendente com mais de uma informacao.

SCENARIO_ID="tattoo-multi-info-multiturn-recovery"
SCENARIO_TITLE="Tattoo multi-info multi-turn: recupera local e altura"
SCENARIO_TYPE="http_multiturn"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

STEP_COUNT="2"
STEP_WAIT_SECONDS="2"

MESSAGE_1="quero uma rosa fineline"
EXPECTED_STATE_1="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_1="medio"
EXPECTED_BOT_REGEX_1="parte do corpo|local|onde"
FORBIDDEN_BOT_REGEX_1="qual tua altura|qual a tua altura|qual sua altura|foto do local|orc_"
EXPECTED_POLL_JQ_TRUE_1='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("rosa"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and ((.conversas[0].dados_coletados.local_corpo == null) or (.conversas[0].dados_coletados | has("local_corpo") | not)) and ((.conversas[0].dados_coletados.altura_cm == null) or (.conversas[0].dados_coletados | has("altura_cm") | not))'

MESSAGE_2="na perna, tenho 1,81"
EXPECTED_STATE_2="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_2="medio"
EXPECTED_BOT_REGEX_2="foto|refer[eê]ncia|local"
FORBIDDEN_BOT_REGEX_2="qual tua altura|qual a tua altura|qual sua altura|parte do corpo|qual estilo|que estilo|me conta o que tu quer tatuar|orc_"
EXPECTED_POLL_JQ_TRUE_2='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("rosa"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("perna"; "i")) and .conversas[0].dados_coletados.altura_cm == 181'
