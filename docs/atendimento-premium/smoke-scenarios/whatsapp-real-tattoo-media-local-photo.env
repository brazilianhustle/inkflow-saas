# Smoke Scenario: whatsapp-real-tattoo-media-local-photo
#
# Objetivo:
# Validar via WhatsApp real que uma imagem enviada pela instancia central,
# quando o bot ja pediu foto do local, vira foto_local_msg_id e nao referencia.

SCENARIO_ID="whatsapp-real-tattoo-media-local-photo"
SCENARIO_TITLE="WhatsApp real: tattoo media foto do local"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_tattoo_aguardando_foto_local"
CLEANUP_BEFORE="1"

MESSAGE="segue foto do local"

EXPECTED_STATE="coletando_cadastro,coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="nome completo|data de nascimento|cadastro|foto|local|or[cç]amento|tatuador"
FORBIDDEN_BOT_REGEX="manda(r)? a foto do local|foto de novo|refer[eê]ncia do desenho|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_coletados.foto_local_msg_id != null and (.conversas[0].dados_coletados.refs_imagens_msg_ids == null or (.conversas[0].dados_coletados.refs_imagens_msg_ids | length) == 0) and .conversas[0].dados_coletados.descricao_curta == "rosa" and .conversas[0].dados_coletados.estilo == "fineline" and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and .conversas[0].orcid == null'

SMOKE_MEDIA_MIMETYPE="image/png"
SMOKE_MEDIA_FILE="docs/superpowers/specs/assets/2026-05-04-home-refator-ref/symbols/logo-black-transparent.png"

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
