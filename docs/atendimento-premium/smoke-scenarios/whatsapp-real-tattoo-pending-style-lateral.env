# Smoke scenario: WhatsApp real multi-turn usando Evolution central como remetente.

SCENARIO_ID="whatsapp-real-tattoo-pending-style-lateral"
SCENARIO_TITLE="WhatsApp real multi-turn: Tattoo pending estilo + lateral de tempo"
SCENARIO_TYPE="whatsapp_real_multiturn"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

STEP_COUNT="2"
STEP_WAIT_SECONDS="4"

MESSAGE_1="quero uma hiena na panturrilha, tenho 1.70"
EXPECTED_STATE_1="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_1="medio"
EXPECTED_BOT_REGEX_1="qual estilo|que estilo|estilo"
FORBIDDEN_BOT_REGEX_1="qual tua altura|qual a tua altura|qual sua altura|parte do corpo|qual parte|foto do local|orc_"
EXPECTED_POLL_JQ_TRUE_1='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("hiena"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("panturrilha"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and ((.conversas[0].dados_coletados.estilo == null) or (.conversas[0].dados_coletados | has("estilo") | not))'

MESSAGE_2="realismo
em quantas sessoes seria?"
EXPECTED_STATE_2="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_2="medio"
EXPECTED_BOT_REGEX_2="tempo de sess[aã]o depende|tamanho|detalhe|local|foto"
FORBIDDEN_BOT_REGEX_2="qual estilo|que estilo|qual tua altura|qual a tua altura|qual sua altura|parte do corpo|qual parte|orc_"
EXPECTED_POLL_JQ_TRUE_2='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("hiena"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("panturrilha"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and (.conversas[0].dados_coletados.estilo | test("realismo"; "i"))'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
