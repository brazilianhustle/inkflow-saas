# Smoke Scenario: lateral-tempo-sessao
#
# Objetivo:
# Validar que pergunta sobre duracao recebe resposta consultiva sem promessa exata.

SCENARIO_ID="lateral-tempo-sessao"
SCENARIO_TITLE="Atendimento lateral: tempo de sessao sem promessa exata"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quanto tempo demora uma tattoo no antebraco?"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="depende|tamanho|detalhe|local|tatuador|avali"
FORBIDDEN_BOT_REGEX="[0-9]+ ?h|[0-9]+ horas|garantido|certeza"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "quanto tempo demora uma tattoo no antebraco?" and .context_metadata.router_intent == "tempo_sessao" and .context_metadata.router_reason == "session_duration_or_number_of_sessions_question" and .context_metadata.router_confidence >= 0.8 and .context_metadata.router_risk == "medium" and .context_metadata.router_can_mutate_state == false)'
