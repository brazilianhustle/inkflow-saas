# Smoke Scenario: tenant-style-out-of-catalog
#
# Objetivo:
# Validar que estilo reconhecido fora do catalogo aceito do tenant nao vira dado
# coletado, nao chama LLM e responde limite de escopo do estudio com estado seguro.

SCENARIO_ID="tenant-style-out-of-catalog"
SCENARIO_TITLE="Tenant/config: estilo fora do catalogo aceito"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

CLEANUP_BEFORE="1"

MESSAGE="voces fazem old school?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="estilo|foco|estudio|adaptar|avaliar"
FORBIDDEN_BOT_REGEX="R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|orc_|qual tua altura|parte do corpo|me conta o que tu pensa em tatuar|foto do local"
FORBIDDEN_TAIL_REGEX="pipeline batch failed|unhandled|runAgent failed|openai"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null and ((.conversas[0].dados_coletados.estilo // null) == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "voces fazem old school?" and .context_metadata.router_intent == "tenant_unsupported_style" and .context_metadata.router_reason == "tenant_style_not_accepted" and .context_metadata.router_can_mutate_state == false and .context_metadata.tenant_context_layer == "tenant_context_manager" and .context_metadata.tenant_context_has_style_catalog == true and .context_metadata.tenant_context_has_accepted_styles == true)'
