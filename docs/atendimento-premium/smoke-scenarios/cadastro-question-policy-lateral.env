# Smoke Scenario: cadastro-question-policy-lateral
#
# Objetivo:
# Validar que uma duvida lateral durante cadastro e respondida sem perder
# a pergunta pendente de data de nascimento.

SCENARIO_ID="cadastro-question-policy-lateral"
SCENARIO_TITLE="Cadastro QuestionPolicy: lateral preserva pergunta pendente"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"

MESSAGE="quanto tempo demora?"
EXPECTED_STATE="coletando_cadastro"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="tempo de sessão|tempo de sessao|data de nascimento"
FORBIDDEN_BOT_REGEX="tatuador vai avaliar|valor certinho|e-?mail|email|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == null or (.conversas[0].dados_cadastro | has("data_nascimento") | not)) and (.conversas[0].dados_cadastro.email == null or (.conversas[0].dados_cadastro | has("email") | not)) and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | (any($logs[]; .agent_name == "conversation_router" and .client_input_text == "quanto tempo demora?" and .context_metadata.router_intent == "tempo_sessao" and .context_metadata.router_can_mutate_state == false) and any($logs[]; .agent_name == "workflow_manager" and .client_input_text == "quanto tempo demora?" and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "cadastro" and .context_metadata.workflow_to_state == "cadastro" and .context_metadata.workflow_transition_allowed == false and .context_metadata.workflow_reason == "state_preserved_by_router_policy" and .context_metadata.workflow_missing_cadastro_count >= 1))'
