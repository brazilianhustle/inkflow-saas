# Smoke Scenario: lateral-preco-generico
#
# Objetivo:
# Validar que uma pergunta preco generico nao inventa valor e retoma atendimento.

SCENARIO_ID="lateral-preco-generico"
SCENARIO_TITLE="Atendimento lateral: preco generico sem inventar valor"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quanto fica uma rosa fineline no braco?"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="depende|tatuador|avali"
FORBIDDEN_BOT_REGEX="R\\$|[0-9]+ reais|fechado por|fica [0-9]"
