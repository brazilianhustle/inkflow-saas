# Smoke Scenario: whatsapp-real-tattoo-media-ambiguous-confirm-local
#
# Objetivo:
# Validar em cadeia real central -> bot que "e local" promove a imagem ambigua
# previa para foto_local_msg_id.

SCENARIO_ID="whatsapp-real-tattoo-media-ambiguous-confirm-local"
SCENARIO_TITLE="WhatsApp real: confirmar foto ambigua como local"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="${SMOKE_EVO_SENDER_INSTANCE:-central}"
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"

SETUP="seed_tattoo_foto_ambigua_aguardando_confirmacao"
CLEANUP_BEFORE="1"

MESSAGE="é local do corpo"
EXPECTED_STATE="coletando_cadastro"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="foto do local|nome completo|data de nascimento|cadastro"
FORBIDDEN_BOT_REGEX="manda(r)? a foto do local|foto de novo|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_coletados.foto_local_msg_id == 11951 and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and (.conversas[0].dados_coletados.refs_imagens_msg_ids | length) == 1 and .conversas[0].dados_coletados.descricao_curta == "rosa" and .conversas[0].dados_coletados.estilo == "fineline" and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and .conversas[0].orcid == null'
