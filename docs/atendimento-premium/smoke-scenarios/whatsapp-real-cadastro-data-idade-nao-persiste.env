# Smoke Scenario: whatsapp-real-cadastro-data-idade-nao-persiste
#
# Objetivo:
# Validar via WhatsApp real que idade isolada durante cadastro nao persiste
# data_nascimento inventada e pede data completa.

SCENARIO_ID="whatsapp-real-cadastro-data-idade-nao-persiste"
SCENARIO_TITLE="WhatsApp real: idade isolada nao persiste data inventada"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"

MESSAGE="tenho 31 anos"

EXPECTED_STATE="coletando_cadastro"
SMOKE_REQUIRE_ORCID="0"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="data|nascimento|completa|registro|maioridade"
FORBIDDEN_BOT_REGEX="or[cç]amento liberado|valor certinho|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|idade n[aã]o [eé] suficiente"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == null) and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "workflow_manager" and .client_input_text == "tenho 31 anos" and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "cadastro" and .context_metadata.workflow_to_state == "cadastro" and .context_metadata.workflow_transition_allowed == false and .context_metadata.workflow_reason == "requirements_missing" and .context_metadata.workflow_missing_cadastro_count == 2 and .context_metadata.workflow_missing_tattoo_count == 0)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
