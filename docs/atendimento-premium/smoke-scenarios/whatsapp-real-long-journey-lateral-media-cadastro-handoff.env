# Smoke Scenario: WhatsApp real long-journey-lateral-media-cadastro-handoff
#
# Jornada longa real enviada pela Evolution central para o numero oficial do bot.

SCENARIO_ID="whatsapp-real-long-journey-lateral-media-cadastro-handoff"
SCENARIO_TITLE="WhatsApp real: jornada longa lateral, midia, cadastro e handoff"
SCENARIO_TYPE="whatsapp_real_multiturn"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

STEP_COUNT="6"
STEP_WAIT_SECONDS="4"

MESSAGE_1="como funciona o orçamento?"
EXPECTED_STATE_1="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_1="medio"
EXPECTED_BOT_REGEX_1="entendo tua ideia|infos principais|tatuador avalia|valor"
FORBIDDEN_BOT_REGEX_1="R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE_1='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null'

MESSAGE_2="quero uma rosa fineline no antebraco, tenho 1.70"
EXPECTED_STATE_2="coletando_tattoo"
EXPECTED_COPY_RISK_MAX_2="medio"
EXPECTED_BOT_REGEX_2="foto|local|refer[eê]ncia"
FORBIDDEN_BOT_REGEX_2="qual estilo|que estilo|parte do corpo|qual tua altura|qual a tua altura|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE_2='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null and (.conversas[0].dados_coletados.descricao_curta | test("rosa"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and .conversas[0].dados_coletados.tentativas_foto_local == 1'

MESSAGE_3="segue foto do local"
EXPECTED_HUMAN_TEXT_3="segue foto do local"
EXPECTED_STATE_3="coletando_cadastro"
EXPECTED_COPY_RISK_MAX_3="medio"
EXPECTED_BOT_REGEX_3="foto do local|nome completo|cadastro"
FORBIDDEN_BOT_REGEX_3="manda(r)? a foto do local|qual estilo|parte do corpo|qual tua altura|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE_3='.conversas[0].estado_agente == "coletando_cadastro" and .conversas[0].orcid == null and .conversas[0].dados_coletados.foto_local_msg_id != null and (.conversas[0].dados_coletados.descricao_curta | test("rosa"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and .conversas[0].dados_coletados.tentativas_foto_local == 1'
SMOKE_MEDIA_MIMETYPE_3="image/png"
SMOKE_MEDIA_FILE_3="docs/superpowers/specs/assets/2026-05-04-home-refator-ref/symbols/logo-black-transparent.png"

MESSAGE_4="Joao Silva"
EXPECTED_STATE_4="coletando_cadastro"
EXPECTED_COPY_RISK_MAX_4="baixo"
EXPECTED_BOT_REGEX_4="data de nascimento"
FORBIDDEN_BOT_REGEX_4="nome completo|foto do local|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE_4='.conversas[0].estado_agente == "coletando_cadastro" and .conversas[0].orcid == null and .conversas[0].dados_cadastro.nome == "Joao Silva" and ((.conversas[0].dados_cadastro.data_nascimento == null) or (.conversas[0].dados_cadastro | has("data_nascimento") | not))'

MESSAGE_5="12/03/1995"
EXPECTED_STATE_5="coletando_cadastro"
EXPECTED_COPY_RISK_MAX_5="medio"
EXPECTED_BOT_REGEX_5="e-?mail|seguir sem"
FORBIDDEN_BOT_REGEX_5="nome completo|data de nascimento completa|foto do local|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE_5='.conversas[0].estado_agente == "coletando_cadastro" and .conversas[0].orcid == null and .conversas[0].dados_cadastro.nome == "Joao Silva" and .conversas[0].dados_cadastro.data_nascimento == "1995-03-12"'

MESSAGE_6="pode seguir sem email"
EXPECTED_STATE_6="aguardando_tatuador"
EXPECTED_COPY_RISK_MAX_6="baixo"
EXPECTED_BOT_REGEX_6="tatuador|avaliar|retorno|valor"
FORBIDDEN_BOT_REGEX_6="nome completo|data de nascimento|foto do local|manda teu e-?mail|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o"
EXPECTED_POLL_JQ_TRUE_6='.conversas[0].estado_agente == "aguardando_tatuador" and (.conversas[0].orcid | type == "string") and (.conversas[0].orcid | startswith("orc_")) and .conversas[0].dados_cadastro.nome == "Joao Silva" and .conversas[0].dados_cadastro.data_nascimento == "1995-03-12" and .conversas[0].dados_cadastro.email_recusado == true and .conversas[0].dados_coletados.foto_local_msg_id != null'
EXPECTED_AGENT_LOG_JQ_TRUE_6='.[] | select(.agent_name == "workflow_manager" and (.client_input_text | contains("pode seguir sem email")) and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "cadastro" and .context_metadata.workflow_to_state == "aguardando_tatuador" and .context_metadata.workflow_transition_allowed == true and .context_metadata.workflow_reason == "cadastro_and_tattoo_complete" and .context_metadata.workflow_handoff_package_required == true and .context_metadata.workflow_handoff_package_version == "handoff_package_v1" and (.context_metadata.workflow_handoff_package_trace_id | startswith("hp_")))'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
