# Smoke Scenario: whatsapp-real-cadastro-menoridade-handoff-humano
#
# Objetivo:
# Validar via WhatsApp real que menoridade explicita aciona handoff humano
# seguro, sem criar orcamento automatico.

SCENARIO_ID="whatsapp-real-cadastro-menoridade-handoff-humano"
SCENARIO_TITLE="WhatsApp real: menoridade aciona handoff humano"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"

MESSAGE="12/03/2015"

EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="0"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="menor|18|tatuador|seguran[cç]a|respons[aá]vel"
FORBIDDEN_BOT_REGEX="or[cç]amento liberado|valor certinho|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|Qual tua altura|parte do corpo|estilo|Pra montar tua proposta"
FORBIDDEN_TAIL_REGEX="enviar-orcamento-tatuador|pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == "2015-03-12") and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "escalation_manager" and .client_input_text == "12/03/2015" and .context_metadata.escalation_reason_code == "minor_age" and .context_metadata.escalation_severity == "high" and .context_metadata.escalation_requires_orcid == false)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
