# Smoke Scenario: tattoo-gatilho-tenant-handoff
#
# Objetivo:
# Validar que gatilhos de handoff configurados no tenant param a coleta
# deterministica e acionam humano antes de preco/formulario.

SCENARIO_ID="tattoo-gatilho-tenant-handoff"
SCENARIO_TITLE="Tattoo: gatilho do tenant aciona handoff humano"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quero tatuar no rosto quanto fica?"

EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="0"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="regi[aã]o|caso|tatuador|pessoa do est[uú]dio|seguran[cç]a|assumir"
FORBIDDEN_BOT_REGEX="or[cç]amento liberado|valor certinho|O valor depende|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|Qual tua altura|parte do corpo|estilo|Pra montar tua proposta"
FORBIDDEN_TAIL_REGEX="enviar-orcamento-tatuador|pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].orcid == null'
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | (any($logs[]; .agent_name == "conversation_router" and .client_input_text == "quero tatuar no rosto quanto fica?" and .context_metadata.router_intent == "tenant_handoff_trigger" and .context_metadata.router_reason == "tenant_configured_handoff_trigger_detected" and .context_metadata.router_can_mutate_state == true and .context_metadata.router_has_matched_tenant_trigger == true and .context_metadata.router_matched_tenant_trigger == "rosto" and .context_metadata.tenant_context_layer == "tenant_context_manager" and .context_metadata.tenant_context_handoff_triggers_source == "custom" and .context_metadata.tenant_context_has_handoff_triggers == true and .context_metadata.tenant_context_gatilhos_handoff_count >= 1) and any($logs[]; .agent_name == "workflow_manager" and .client_input_text == "quero tatuar no rosto quanto fica?" and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "tattoo" and .context_metadata.workflow_to_state == "aguardando_tatuador" and .context_metadata.workflow_transition_allowed == true and .context_metadata.workflow_reason == "escalation_required" and .context_metadata.workflow_escalation_reason_code == "tenant_handoff_trigger" and .context_metadata.workflow_escalation_requires_orcid == false) and any($logs[]; .agent_name == "escalation_manager" and .client_input_text == "quero tatuar no rosto quanto fica?" and .context_metadata.escalation_reason_code == "tenant_handoff_trigger" and .context_metadata.escalation_source == "tenant_rules" and .context_metadata.escalation_severity == "high" and .context_metadata.escalation_requires_orcid == false))'
