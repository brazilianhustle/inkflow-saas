# Smoke Scenario: whatsapp-real-lateral-pergunta-imagem-sem-midia
#
# Objetivo:
# Validar via WhatsApp real que pergunta sobre imagem sem midia disponivel
# pede reenvio de foto sem voltar ao formulario desconectado.

SCENARIO_ID="whatsapp-real-lateral-pergunta-imagem-sem-midia"
SCENARIO_TITLE="WhatsApp real: pergunta sobre imagem sem midia"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="o que você viu na imagem?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="imagem clara|foto de novo|manda(r)? a foto"
FORBIDDEN_BOT_REGEX="parte do corpo|qual tua altura|qual estilo|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|tatuador vai avaliar"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "o que você viu na imagem?" and .context_metadata.router_intent == "pergunta_imagem" and .context_metadata.router_reason == "image_interpretation_question_without_media_context" and .context_metadata.router_confidence >= 0.8 and .context_metadata.router_risk == "medium" and .context_metadata.router_can_mutate_state == false)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
