# Smoke Scenario: whatsapp-real-tattoo-media-ambiguous-photo-clarification
#
# Objetivo:
# Validar via WhatsApp real que uma imagem sem legenda clara pede
# classificacao entre referencia e local sem perder dados ja coletados.

SCENARIO_ID="whatsapp-real-tattoo-media-ambiguous-photo-clarification"
SCENARIO_TITLE="WhatsApp real: tattoo media foto ambigua pede classificacao"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_tattoo_parcial_foto_ambigua"
CLEANUP_BEFORE="1"

MESSAGE=""
EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="refer[eê]ncia|desenho|local do corpo|qual dos dois"
FORBIDDEN_BOT_REGEX="Pra liberar teu or[cç]amento|liberar teu or[cç]amento|nome completo|data de nascimento|manda(r)? a foto do local|foto de novo|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_coletados.foto_local_msg_id == null and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and (.conversas[0].dados_coletados.refs_imagens_msg_ids | length) == 1 and .conversas[0].dados_coletados.descricao_curta == "rosa" and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and (.conversas[0].dados_coletados.estilo == null) and .conversas[0].orcid == null'

SMOKE_MEDIA_MIMETYPE="image/png"
SMOKE_MEDIA_FILE="docs/superpowers/specs/assets/2026-05-04-home-refator-ref/symbols/logo-black-transparent.png"

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
