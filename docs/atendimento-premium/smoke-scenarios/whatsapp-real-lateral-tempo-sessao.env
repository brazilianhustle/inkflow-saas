# Smoke Scenario: whatsapp-real-lateral-tempo-sessao
#
# Objetivo:
# Validar via WhatsApp real que pergunta de tempo de sessao recebe resposta
# consultiva sem prometer duracao exata.

SCENARIO_ID="whatsapp-real-lateral-tempo-sessao"
SCENARIO_TITLE="WhatsApp real: tempo de sessao sem promessa exata"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quanto tempo demora pra fazer uma tattoo no braço?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="tempo|sess[aã]o|depende|tamanho|detalhe|local|avali"
FORBIDDEN_BOT_REGEX="[0-9]+\\s*(h|hora|horas|min|minutos)|garanto|garantido|mesmo dia|uma sess[aã]o certeza|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "quanto tempo demora pra fazer uma tattoo no braço?" and .context_metadata.router_intent == "tempo_sessao" and .context_metadata.router_reason == "session_duration_or_number_of_sessions_question" and .context_metadata.router_confidence >= 0.8 and .context_metadata.router_risk == "medium" and .context_metadata.router_can_mutate_state == false)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
