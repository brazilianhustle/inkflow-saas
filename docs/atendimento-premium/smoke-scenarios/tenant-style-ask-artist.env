# Smoke Scenario: tenant-style-ask-artist
#
# Objetivo:
# Validar que `tenant_product.style_policy.out_of_catalog_behavior=ask_artist`
# escala estilo fora do foco para avaliacao humana e registra metadata Slice 8.

SCENARIO_ID="tenant-style-ask-artist"
SCENARIO_TITLE="Tenant/product: estilo fora do foco exige avaliacao do tatuador"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

CLEANUP_BEFORE="1"
SETUP="tenant_style_ask_artist"

MESSAGE="voces fazem old school?"

EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="0"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="old school|confirmar sozinho|tatuador|rola seguir nessa linha"
FORBIDDEN_BOT_REGEX="R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|orc_|qual tua altura|parte do corpo|me conta o que tu pensa em tatuar|foto do local|nao esta no foco|adaptar pra outro estilo|avalia[cç][aã]o direta|pessoa do est[uú]dio|precisa avaliar|acionar"
FORBIDDEN_TAIL_REGEX="pipeline batch failed|unhandled|runAgent failed|openai"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "aguardando_tatuador" and .conversas[0].orcid == null and ((.conversas[0].dados_coletados.estilo // null) == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "voces fazem old school?" and .context_metadata.router_intent == "tenant_style_artist_review" and .context_metadata.router_reason == "tenant_style_artist_review_required" and .context_metadata.router_can_mutate_state == true and .context_metadata.router_resolver_used == "conversation_router.tenant_style_artist_review" and .context_metadata.tenant_context_product_out_of_catalog_behavior == "ask_artist" and .llm_output_parsed.escalation.source == "tenant_product" and .llm_output_parsed.escalation.reason_code == "tenant_style_artist_review")'
