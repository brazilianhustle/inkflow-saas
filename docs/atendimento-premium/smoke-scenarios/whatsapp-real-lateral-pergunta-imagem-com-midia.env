# Smoke Scenario: whatsapp-real-lateral-pergunta-imagem-com-midia
#
# Objetivo:
# Validar via WhatsApp real que a instancia central consegue enviar imagem
# para o numero oficial do bot e que o bot responde a pergunta visual sem
# cair no fallback de ausencia de midia.

SCENARIO_ID="whatsapp-real-lateral-pergunta-imagem-com-midia"
SCENARIO_TITLE="WhatsApp real: pergunta sobre imagem com midia"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="o que você viu na imagem?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="imagem|foto|refer[eê]ncia|desenho|local|corpo"
FORBIDDEN_BOT_REGEX="foto de novo|não estou vendo uma imagem clara|nao estou vendo uma imagem clara|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"

SMOKE_MEDIA_MIMETYPE="image/png"
SMOKE_MEDIA_FILE="docs/superpowers/specs/assets/2026-05-04-home-refator-ref/symbols/logo-black-transparent.png"

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
