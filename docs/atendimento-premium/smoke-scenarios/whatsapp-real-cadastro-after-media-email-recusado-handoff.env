# Smoke Scenario: WhatsApp real cadastro-after-media-email-recusado-handoff

SCENARIO_ID="whatsapp-real-cadastro-after-media-email-recusado-handoff"
SCENARIO_TITLE="WhatsApp real: cadastro pos-midia com email recusado dispara handoff"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_pos_midia_aguardando_email"
CLEANUP_BEFORE="1"

MESSAGE=$'pode seguir sem email\nquanto tempo demora?'
EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="1"

EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="tempo de sess[aã]o|tatuador vai avaliar|valor certinho"
FORBIDDEN_BOT_REGEX="nome completo|data de nascimento|foto do local|refer[eê]ncia|manda teu e-?mail"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "aguardando_tatuador" and (.conversas[0].orcid | type == "string") and (.conversas[0].orcid | startswith("orc_")) and .conversas[0].dados_cadastro.nome == "Joao Silva" and .conversas[0].dados_cadastro.data_nascimento == "1995-03-12" and .conversas[0].dados_cadastro.email_recusado == true and .conversas[0].dados_coletados.foto_local_msg_id == 12632 and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and .conversas[0].dados_coletados.refs_imagens_msg_ids[0] == 11951'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "workflow_manager" and (.client_input_text | contains("pode seguir sem email")) and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "cadastro" and .context_metadata.workflow_to_state == "aguardando_tatuador" and .context_metadata.workflow_transition_allowed == true and .context_metadata.workflow_reason == "cadastro_and_tattoo_complete" and .context_metadata.workflow_handoff_package_required == true and .context_metadata.workflow_handoff_package_version == "handoff_package_v1" and (.context_metadata.workflow_handoff_package_trace_id | startswith("hp_")))'

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
