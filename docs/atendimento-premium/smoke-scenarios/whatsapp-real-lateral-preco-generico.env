# Smoke Scenario: whatsapp-real-lateral-preco-generico
#
# Objetivo:
# Validar via WhatsApp real que pergunta de preco nao recebe valor inventado.

SCENARIO_ID="whatsapp-real-lateral-preco-generico"
SCENARIO_TITLE="WhatsApp real: preco generico sem inventar valor"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quanto fica uma rosa fineline no braco?"

EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="depende|tatuador|avali"
FORBIDDEN_BOT_REGEX="R\\$|[0-9]+ reais|fechado por|fica [0-9]"
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | (any($logs[]; .agent_name == "conversation_router" and .client_input_text == "quanto fica uma rosa fineline no braco?" and .context_metadata.router_intent == "preco_generico" and .context_metadata.router_reason == "generic_price_question_without_negotiation" and .context_metadata.router_confidence >= 0.8 and .context_metadata.router_risk == "high" and .context_metadata.router_can_mutate_state == false) and any($logs[]; .agent_name == "workflow_manager" and .client_input_text == "quanto fica uma rosa fineline no braco?" and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "tattoo" and .context_metadata.workflow_to_state == "tattoo" and .context_metadata.workflow_transition_allowed == false and .context_metadata.workflow_reason == "state_preserved_by_router_policy" and .context_metadata.workflow_can_mutate_state == false and .context_metadata.workflow_blocked_mutation == false))'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
