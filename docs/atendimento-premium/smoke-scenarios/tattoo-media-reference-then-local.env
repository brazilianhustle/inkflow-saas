# Smoke Scenario: tattoo-media-reference-then-local
#
# Objetivo:
# Validar que, apos o cliente confirmar a imagem ambigua como referencia,
# a proxima foto enviada como local vira foto_local_msg_id sem perder a referencia.

SCENARIO_ID="tattoo-media-reference-then-local"
SCENARIO_TITLE="Tattoo media: referencia confirmada depois foto local"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_tattoo_ref_confirmada_aguardando_foto_local"
CLEANUP_BEFORE="1"

MESSAGE="segue foto do local"
EXPECTED_HUMAN_TEXT="segue foto do local"

EXPECTED_STATE="coletando_cadastro"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="Recebi a foto do local|nome completo|cadastro|or[cç]amento"
FORBIDDEN_BOT_REGEX="refer[eê]ncia do desenho|manda(r)? a foto do local|foto de novo|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_coletados.foto_local_msg_id != null and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and (.conversas[0].dados_coletados.refs_imagens_msg_ids | length) == 1 and .conversas[0].dados_coletados.refs_imagens_msg_ids[0] == 11951 and .conversas[0].dados_coletados.descricao_curta == "rosa" and .conversas[0].dados_coletados.estilo == "fineline" and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and .conversas[0].orcid == null'

SMOKE_MEDIA_MIMETYPE="image/png"
SMOKE_MEDIA_FILE="docs/superpowers/specs/assets/2026-05-04-home-refator-ref/symbols/logo-black-transparent.png"
