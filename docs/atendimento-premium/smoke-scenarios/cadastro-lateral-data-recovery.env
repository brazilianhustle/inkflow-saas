# Smoke Scenario: cadastro-lateral-data-recovery
#
# Objetivo:
# Validar em HTTP multi-turn que uma duvida lateral durante cadastro nao perde
# a pergunta pendente e que a resposta seguinte de data segue funcionando.

SCENARIO_ID="cadastro-lateral-data-recovery"
SCENARIO_TITLE="Cadastro multi-turn: lateral depois data"
SCENARIO_TYPE="http_multiturn"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"
STEP_COUNT="2"
STEP_WAIT_SECONDS="2"

MESSAGE_1="quanto tempo demora?"
EXPECTED_STATE_1="coletando_cadastro"
EXPECTED_COPY_RISK_MAX_1="baixo"
EXPECTED_BOT_REGEX_1="tempo de sessão|tempo de sessao|data de nascimento"
FORBIDDEN_BOT_REGEX_1="tatuador vai avaliar|valor certinho|e-?mail|email|orc_"
EXPECTED_POLL_JQ_TRUE_1='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == null or (.conversas[0].dados_cadastro | has("data_nascimento") | not)) and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE_1='. as $logs | any($logs[]; .agent_name == "workflow_manager" and .client_input_text == "quanto tempo demora?" and .context_metadata.workflow_reason == "state_preserved_by_router_policy")'

MESSAGE_2="12/03/1995"
EXPECTED_STATE_2="coletando_cadastro"
EXPECTED_COPY_RISK_MAX_2="medio"
EXPECTED_BOT_REGEX_2="e-?mail|email"
FORBIDDEN_BOT_REGEX_2="data de nascimento|tatuador vai avaliar|valor certinho|orc_"
EXPECTED_POLL_JQ_TRUE_2='.conversas[0].dados_cadastro.nome == "Joao Silva" and .conversas[0].dados_cadastro.data_nascimento == "1995-03-12" and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE_2='. as $logs | any($logs[]; .agent_name == "conversation_router" and .client_input_text == "12/03/1995" and .context_metadata.router_intent == "cadastro_pending_answer" and .context_metadata.router_reason == "pending_data_nascimento_answered")'
