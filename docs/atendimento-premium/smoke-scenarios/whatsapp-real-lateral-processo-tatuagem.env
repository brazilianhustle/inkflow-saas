# Smoke Scenario: whatsapp-real-lateral-processo-tatuagem
#
# Objetivo:
# Validar via WhatsApp real que pergunta sobre processo recebe explicacao curta,
# consultiva e retoma a coleta sem acionar fechamento operacional.

SCENARIO_ID="whatsapp-real-lateral-processo-tatuagem"
SCENARIO_TITLE="WhatsApp real: processo de tatuagem consultivo"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="como funciona pra fazer uma tattoo?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="ideia|refer[eê]ncia|tatuador|avali|or[cç]amento|proposta"
FORBIDDEN_BOT_REGEX="sou uma ia|sistema|prompt|erro|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "como funciona pra fazer uma tattoo?" and .context_metadata.router_intent == "processo_tatuagem" and .context_metadata.router_reason == "tattoo_process_or_booking_flow_question" and .context_metadata.router_confidence >= 0.8 and .context_metadata.router_risk == "medium" and .context_metadata.router_can_mutate_state == false)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
