# Smoke Scenario: WhatsApp real post-handoff-media-forwarding

SCENARIO_ID="whatsapp-real-post-handoff-media-forwarding"
SCENARIO_TITLE="WhatsApp real: pos-handoff reencaminha midia adicional ao tatuador"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_pos_handoff_aguardando_tatuador"
CLEANUP_BEFORE="1"

MESSAGE="mais uma referencia"
EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="1"
SMOKE_REQUIRE_AI_RESPONSE="0"

SMOKE_MEDIA_FILE="docs/superpowers/specs/assets/2026-05-04-home-refator-ref/symbols/logo-white-header-240h.png"
SMOKE_MEDIA_MIMETYPE="image/png"

EXPECTED_TAIL_REGEX='pos-handoff-midia-encaminhada'
FORBIDDEN_TAIL_REGEX='pos-handoff foto falhou|telegram-[45][0-9][0-9]|pipeline batch failed|unhandled'
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "aguardando_tatuador" and .conversas[0].orcid == "orc_poshandoff" and ([.mensagens[]? | select(.message.type=="human" and .message.content=="mais uma referencia" and .message.media_mimetype=="image/png" and .status=="processed")] | length) >= 1 and ([.mensagens[]? | select(.message.type=="ai")] | length) == 0'

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
