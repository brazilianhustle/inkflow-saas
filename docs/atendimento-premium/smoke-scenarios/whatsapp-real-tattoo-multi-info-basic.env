# Smoke scenario: WhatsApp real usando Evolution central como remetente.

SCENARIO_ID="whatsapp-real-tattoo-multi-info-basic"
SCENARIO_TITLE="WhatsApp real: Tattoo multi-info basico"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quero uma rosa fineline no antebraco, tenho 1,70"
EXPECTED_STATE="coletando_tattoo"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="foto|refer[eê]ncia|local"
FORBIDDEN_BOT_REGEX="qual tua altura|qual a tua altura|qual sua altura|parte do corpo|qual estilo|que estilo|me conta o que tu quer tatuar|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("rosa"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço|braco|braço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
