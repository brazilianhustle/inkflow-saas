# Smoke scenario: WhatsApp real usando Evolution central como remetente.

SCENARIO_ID="whatsapp-real-cadastro-question-policy-nome"
SCENARIO_TITLE="WhatsApp real: Cadastro QuestionPolicy resolve nome completo pendente"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_aguardando_nome"
CLEANUP_BEFORE="1"

MESSAGE="Joao Silva"
EXPECTED_STATE="coletando_cadastro"

EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="data de nascimento"
FORBIDDEN_BOT_REGEX="nome completo|or[çc]amento.*tatuador|valor certinho"
EXPECTED_POLL_JQ_TRUE='.conversa.dados_cadastro.nome == "Joao Silva" and (.conversa.dados_cadastro.data_nascimento == null) and (.conversa.orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "Joao Silva" and .context_metadata.router_intent == "cadastro_pending_answer" and .context_metadata.router_reason == "pending_nome_completo_answered" and .context_metadata.router_can_mutate_state == true)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
