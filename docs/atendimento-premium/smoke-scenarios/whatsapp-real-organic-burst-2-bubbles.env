# Smoke Scenario: WhatsApp real organic burst 2 bubbles
#
# Organic Conversation Sentinel Pack.
# Variante curta para provar que o bot consolida intencao + briefing quando
# o cliente manda informacao em duas bolhas reais.

SCENARIO_ID="whatsapp-real-organic-burst-2-bubbles"
SCENARIO_TITLE="WhatsApp real: conversa organica em 2 bolhas"
SCENARIO_TYPE="whatsapp_real_burst"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

STEP_COUNT="2"
BURST_INTERVAL_SECONDS="1"

MESSAGE_1="quero fzr uma tattoo"
MESSAGE_2="um dragao grandao na perna"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="drag[aã]o|perna|grand"
FORBIDDEN_BOT_REGEX="parte do corpo|qual local|onde tu quer tatuar|^Qual tua altura\\??$|^Qual a tua altura\\??$|me chamo Assistente|muito prazer|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE='(.mensagens | map(select(.message.type=="human")) | length) >= 2 and (.mensagens | map(select(.message.type=="ai")) | length) == 1 and .conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null and (.conversas[0].dados_coletados.descricao_curta | test("drag"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("perna"; "i"))'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and (.client_input_text | test("tattoo[\\s\\S]*drag|drag[\\s\\S]*perna"; "i")) and .context_metadata.router_can_mutate_state == true)'

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
