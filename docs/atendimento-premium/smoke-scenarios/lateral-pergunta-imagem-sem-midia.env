# Smoke Scenario: lateral-pergunta-imagem-sem-midia
#
# Objetivo:
# Validar que pergunta sobre imagem sem midia disponivel nao cai no formulario
# desconectado e pede reenvio de forma segura.

SCENARIO_ID="lateral-pergunta-imagem-sem-midia"
SCENARIO_TITLE="Atendimento lateral: pergunta sobre imagem sem midia"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="o que você viu na imagem?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="imagem clara|foto de novo|manda(r)? a foto"
FORBIDDEN_BOT_REGEX="parte do corpo|qual tua altura|qual estilo|R\\$|fechado por|agendar|sinal|tatuador vai avaliar"
