# Smoke Scenario: lateral-portfolio-disponivel
#
# Objetivo:
# Validar que pedido de portfolio com portfolio cadastrado responde sem URL manual,
# aciona o fluxo de portfolio e nao muda estado critico.

SCENARIO_ID="lateral-portfolio-disponivel"
SCENARIO_TITLE="Atendimento lateral: portfolio disponivel sem URL manual"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="tem exemplos de fineline?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="mando|trabalhos|exemplos|refer"
FORBIDDEN_BOT_REGEX="https?://|www\\.|instagram\\.com|R\\$|fechado por"
EXPECTED_TAIL_REGEX="enviar-portfolio|portfolio"
FORBIDDEN_TAIL_REGEX="pipeline batch failed|unhandled|sendMedia falhou"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "tattoo" and .client_input_text == "tem exemplos de fineline?" and .context_metadata.tenant_context_layer == "tenant_context_manager" and .context_metadata.tenant_context_state == "tattoo" and .context_metadata.tenant_context_portfolio_disponivel == true)'
