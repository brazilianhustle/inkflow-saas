# Smoke Scenario: cadastro-idade-menor-handoff-humano
#
# Objetivo:
# Validar que idade explicitamente menor de 18 anos aciona humano sem inventar
# data de nascimento e sem criar orcamento.

SCENARIO_ID="cadastro-idade-menor-handoff-humano"
SCENARIO_TITLE="Cadastro: idade menor explicita aciona humano"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"

MESSAGE="tenho 16 anos"

EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="0"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="menos de 18|tatuador|seguran[cç]a|respons[aá]vel legal"
FORBIDDEN_BOT_REGEX="data de nascimento completa|or[cç]amento liberado|valor certinho|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
FORBIDDEN_TAIL_REGEX="enviar-orcamento-tatuador|pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == null) and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | (any($logs[]; .agent_name == "conversation_router" and .client_input_text == "tenho 16 anos" and .context_metadata.router_intent == "minor_age_explicit" and .context_metadata.router_reason == "explicit_minor_age" and .context_metadata.router_risk == "high" and .context_metadata.router_can_mutate_state == true) and any($logs[]; .agent_name == "escalation_manager" and .client_input_text == "tenho 16 anos" and .context_metadata.escalation_reason_code == "minor_age" and .context_metadata.escalation_severity == "high" and .context_metadata.escalation_requires_orcid == false))'
