# Smoke Scenario: cadastro-data-idade-nao-persiste
#
# Objetivo:
# Validar que idade isolada nao vira data de nascimento inventada durante
# cadastro. O bot deve pedir a data completa e manter o estado em cadastro.

SCENARIO_ID="cadastro-data-idade-nao-persiste"
SCENARIO_TITLE="Cadastro: idade isolada nao persiste data"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"

MESSAGE="tenho 30 anos"

EXPECTED_STATE="coletando_cadastro"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="data|nascimento|completa|seguran[cç]a|maioridade|dia|m[eê]s|ano"
FORBIDDEN_BOT_REGEX="aguardando_tatuador|tatuador vai avaliar|or[cç]amento liberado|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == null) and (.conversas[0].orcid == null)'
