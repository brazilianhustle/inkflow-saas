# Smoke Scenario: WhatsApp real post-handoff-text-forwarding

SCENARIO_ID="whatsapp-real-post-handoff-text-forwarding"
SCENARIO_TITLE="WhatsApp real: pos-handoff reencaminha texto adicional ao tatuador"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_pos_handoff_aguardando_tatuador"
CLEANUP_BEFORE="1"

MESSAGE="lembrei de mais um detalhe"
EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="1"
SMOKE_REQUIRE_AI_RESPONSE="0"

EXPECTED_TAIL_REGEX='pos-handoff-mensagem-encaminhada'
FORBIDDEN_TAIL_REGEX='pos-handoff foto falhou|telegram-[45][0-9][0-9]|pipeline batch failed|unhandled'
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "aguardando_tatuador" and .conversas[0].orcid == "orc_poshandoff" and (.mensagens as $msgs | ([ $msgs[]? | select(.message.type=="human" and .message.content=="lembrei de mais um detalhe" and (.message.media_mimetype == null or (.message | has("media_mimetype") | not)) and .status=="processed") | .created_at ] | max // "") as $human_at | $human_at != "" and ([ $msgs[]? | select(.message.type=="ai" and .created_at > $human_at)] | length) == 0)'

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
