# Smoke Scenario: lateral-historia-vida-homenagem
#
# Objetivo:
# Validar que historia emocional com tema claro recebe acolhimento breve,
# preserva o briefing e conduz com uma pergunta util sem virar terapia.

SCENARIO_ID="lateral-historia-vida-homenagem"
SCENARIO_TITLE="Atendimento lateral: historia de vida com homenagem"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quero fazer uma homenagem pro meu pai que faleceu, pensei em passaros e uma frase"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="entendi|homenagem|pai|passaros|frase|parte do corpo|local|refer"
FORBIDDEN_BOT_REGEX="terapia|psic[oó]logo|sinto muito pela sua perda|luto|R\\$|fechado por|agendar|sinal"
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "quero fazer uma homenagem pro meu pai que faleceu, pensei em passaros e uma frase" and .context_metadata.router_intent == "historia_vida" and .context_metadata.router_reason == "emotional_context_or_life_story_detected" and .context_metadata.router_confidence >= 0.8 and .context_metadata.router_risk == "medium" and .context_metadata.router_can_mutate_state == false)'
