# Smoke Scenario: whatsapp-real-tattoo-pedido-humano-handoff
#
# Objetivo:
# Validar via WhatsApp real que pedido explicito de humano/tatuador aciona
# handoff seguro, sem continuar coleta normal.

SCENARIO_ID="whatsapp-real-tattoo-pedido-humano-handoff"
SCENARIO_TITLE="WhatsApp real: pedido humano aciona handoff"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quero falar com o tatuador"

EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="0"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="acionar|tatuador|assumir|orientar|direto"
FORBIDDEN_BOT_REGEX="or[cç]amento liberado|valor certinho|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|Qual tua altura|parte do corpo|estilo|Pra montar tua proposta"
FORBIDDEN_TAIL_REGEX="enviar-orcamento-tatuador|pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].orcid == null'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "escalation_manager" and .client_input_text == "quero falar com o tatuador" and .context_metadata.escalation_reason_code == "human_requested" and .context_metadata.escalation_severity == "medium" and .context_metadata.escalation_requires_orcid == false)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
