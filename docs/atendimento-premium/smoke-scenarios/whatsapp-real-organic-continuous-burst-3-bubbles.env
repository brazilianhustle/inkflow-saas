# Smoke Scenario: WhatsApp real organic continuous burst 3 bubbles
#
# Organic Conversation Sentinel Pack - modo conversa continua.
# Deve ser rodado DEPOIS de um burst inicial na mesma conversa, sem cleanup.
# Prova que o bot nao reabre saudacao como se fosse novo lead.

SCENARIO_ID="whatsapp-real-organic-continuous-burst-3-bubbles"
SCENARIO_TITLE="WhatsApp real: conversa continua em 3 bolhas sem nova saudacao"
SCENARIO_TYPE="whatsapp_real_burst"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="0"

STEP_COUNT="3"
BURST_INTERVAL_SECONDS="1"

MESSAGE_1="opa"
MESSAGE_2="quero fzr uma tattoo"
MESSAGE_3="na perna um dragao bolado grandao"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="drag[aã]o|perna|grand"
FORBIDDEN_BOT_REGEX="Oii|tudo bem|me chamo Assistente|muito prazer|parte do corpo|qual local|onde tu quer tatuar|^Qual tua altura\\??$|^Qual a tua altura\\??$|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE='(.mensagens | map(select(.message.type=="human")) | length) >= 3 and (.mensagens | map(select(.message.type=="ai")) | length) == 1 and .conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null and (.conversas[0].dados_coletados.descricao_curta | test("drag"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("perna"; "i"))'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and (.client_input_text | test("opa[\\s\\S]*tattoo[\\s\\S]*drag|tattoo[\\s\\S]*perna[\\s\\S]*drag"; "i")) and .context_metadata.router_can_mutate_state == true and (.context_metadata.router_is_first_contact != true) and .context_metadata.session_queue_observed == true and .context_metadata.session_queue_version == "session_queue_v1" and .context_metadata.session_queue_batch_message_count >= 3 and .context_metadata.session_queue_silence_wait_ms >= 10000)'

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
