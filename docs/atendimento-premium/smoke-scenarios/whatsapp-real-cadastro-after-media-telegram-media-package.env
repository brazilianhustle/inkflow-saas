# Smoke Scenario: WhatsApp real cadastro-after-media-telegram-media-package

SCENARIO_ID="whatsapp-real-cadastro-after-media-telegram-media-package"
SCENARIO_TITLE="WhatsApp real: cadastro pos-midia audita pacote Telegram com midia"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_pos_midia_aguardando_email_media_fresca"
CLEANUP_BEFORE="1"

MESSAGE="joao@example.com"
EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="1"

EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="tatuador avaliar|retorno por aqui|valor"
FORBIDDEN_BOT_REGEX="Pra liberar teu or[cç]amento|liberar teu or[cç]amento|Fechado|valor certinho|avaliar com calma|nome completo|data de nascimento|foto do local|refer[eê]ncia|manda teu e-?mail|pode seguir sem email"
EXPECTED_TAIL_REGEX='fotos-orcamento-enviadas.*enviadas[^0-9]*[1-9]'
FORBIDDEN_TAIL_REGEX='falhas_total[^a-zA-Z0-9]*true|mediaGroup falhou|telegram-[45][0-9][0-9]|pipeline batch failed|unhandled'
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "aguardando_tatuador" and (.conversas[0].orcid | type == "string") and (.conversas[0].orcid | startswith("orc_")) and .conversas[0].dados_cadastro.email == "joao@example.com" and (.conversas[0].dados_cadastro.email_recusado != true) and (.conversas[0].dados_coletados.foto_local_msg_id | type == "number") and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and (.conversas[0].dados_coletados.refs_imagens_msg_ids | length) >= 1 and (.conversas[0].dados_coletados.foto_local_file_id | type == "string") and (.conversas[0].dados_coletados.refs_imagens_file_ids | type == "array") and (.conversas[0].dados_coletados.refs_imagens_file_ids | length) >= 1'
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | (any($logs[]; .agent_name == "conversation_router" and .client_input_text == "joao@example.com" and .context_metadata.router_reason == "pending_email_answered") and any($logs[]; .agent_name == "workflow_manager" and .client_input_text == "joao@example.com" and .context_metadata.workflow_reason == "cadastro_and_tattoo_complete" and .context_metadata.workflow_handoff_package_version == "handoff_package_v1" and (.context_metadata.workflow_handoff_package_trace_id | startswith("hp_"))))'

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
