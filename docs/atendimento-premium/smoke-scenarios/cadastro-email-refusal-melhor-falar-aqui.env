# Smoke Scenario: cadastro-email-refusal-melhor-falar-aqui
#
# Objetivo:
# Validar uma segunda variacao natural de recusa do e-mail opcional.

SCENARIO_ID="cadastro-email-refusal-melhor-falar-aqui"
SCENARIO_TITLE="Cadastro: recusa natural de email - melhor falar por aqui"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_cadastro_handoff_email_recusado"
CLEANUP_BEFORE="1"

MESSAGE="melhor falar por aqui"
EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="1"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="tatuador|avaliar|retorno|valor"
FORBIDDEN_BOT_REGEX="e-?mail|email|data de nascimento|nome completo|manda|passa"
FORBIDDEN_TAIL_REGEX="pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.email == null and .conversas[0].dados_cadastro.email_recusado == true and (.conversas[0].orcid | type == "string" and startswith("orc_"))'
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | (any($logs[]; .agent_name == "conversation_router" and .client_input_text == "melhor falar por aqui" and .context_metadata.router_intent == "cadastro_pending_answer" and .context_metadata.router_reason == "pending_email_refused" and .context_metadata.router_can_mutate_state == true) and any($logs[]; .agent_name == "workflow_manager" and .client_input_text == "melhor falar por aqui" and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_from_state == "cadastro" and .context_metadata.workflow_to_state == "aguardando_tatuador" and .context_metadata.workflow_transition_allowed == true and .context_metadata.workflow_reason == "cadastro_and_tattoo_complete"))'
