# Smoke Scenario: tattoo-multi-info-height-size
#
# Objetivo:
# Validar que uma mensagem com tamanho da tattoo + altura da pessoa separa
# `tamanho_cm` de `altura_cm` no mesmo turno e nao repete campos ja respondidos.

SCENARIO_ID="tattoo-multi-info-height-size"
SCENARIO_TITLE="Tattoo multi-info: tamanho da tattoo e altura da pessoa"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quero uma rosa fineline na perna de 5cm, tenho 1,81"
EXPECTED_STATE="coletando_tattoo"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="foto|refer[eê]ncia|local"
FORBIDDEN_BOT_REGEX="qual tua altura|qual a tua altura|qual sua altura|parte do corpo|qual estilo|que estilo|me conta o que tu quer tatuar|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and (.conversas[0].orcid == null) and (.conversas[0].dados_coletados.descricao_curta | test("rosa"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("perna"; "i")) and .conversas[0].dados_coletados.tamanho_cm == 5 and .conversas[0].dados_coletados.altura_cm == 181'
