# Smoke Scenario: voice-policy-first-contact-preco
#
# Wave 24 Micro-slice 1: primeiro contato deterministico com pergunta de preco
# deve responder a duvida e retomar com nome sem apresentacao mecanica.

SCENARIO_ID="voice-policy-first-contact-preco"
SCENARIO_TITLE="Voice Policy: primeiro contato preco sem apresentacao mecanica"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quanto fica uma rosa fineline no braco?"
EXPECTED_STATE="coletando_tattoo"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="^Oii, tudo bem\\.|valor depende|tatuador|avali|como posso te chamar"
FORBIDDEN_BOT_REGEX="Me chamo|muito prazer|R\\$|[0-9]+ reais|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null'
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | (any($logs[]; .agent_name == "conversation_router" and .client_input_text == "quanto fica uma rosa fineline no braco?" and .context_metadata.router_intent == "preco_generico" and .context_metadata.router_reason == "generic_price_question_without_negotiation" and .context_metadata.router_can_mutate_state == false) and any($logs[]; .agent_name == "workflow_manager" and .client_input_text == "quanto fica uma rosa fineline no braco?" and .context_metadata.workflow_layer == "workflow_manager" and .context_metadata.workflow_reason == "state_preserved_by_router_policy"))'
