# Smoke Scenario: whatsapp-real-cadastro-batch-nome-data-lateral
#
# Objetivo:
# Validar via WhatsApp real que, quando o bot pediu nome+data, o cliente pode
# mandar nome, data e duvida lateral no mesmo envio.

SCENARIO_ID="whatsapp-real-cadastro-batch-nome-data-lateral"
SCENARIO_TITLE="WhatsApp real: cadastro batch nome/data + lateral"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_aguardando_nome_data"
CLEANUP_BEFORE="1"

MESSAGE=$'Joao Silva\n12/03/1995\ncomo funciona o orçamento?'
EXPECTED_STATE="coletando_cadastro"

EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="Funciona assim|funciona assim|e-?mail|email"
FORBIDDEN_BOT_REGEX="nome completo|data de nascimento|valor certinho|tatuador vai avaliar|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and .conversas[0].dados_cadastro.data_nascimento == "1995-03-12" and (.conversas[0].dados_cadastro.email == null or (.conversas[0].dados_cadastro | has("email") | not)) and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='. as $logs | any($logs[]; .agent_name == "conversation_router" and .client_input_text == "Joao Silva\n12/03/1995\ncomo funciona o orçamento?" and .context_metadata.router_intent == "processo_tatuagem" and .context_metadata.router_can_mutate_state == false and .context_metadata.router_reason == "tattoo_process_or_booking_flow_question")'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
