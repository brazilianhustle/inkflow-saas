# Smoke Scenario: voice-policy-first-contact-multi-info
#
# Wave 24 Micro-slice 2: primeiro contato deterministico com briefing de tattoo
# quase completo deve pedir foto local sem apresentacao mecanica.

SCENARIO_ID="voice-policy-first-contact-multi-info"
SCENARIO_TITLE="Voice Policy: primeiro contato multi-info sem apresentacao mecanica"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quero uma borboleta fineline na perna, tenho 1.70"
EXPECTED_STATE="coletando_tattoo"

EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="^Oii, tudo bem\\.|foto do local|onde tu quer tatuar"
FORBIDDEN_BOT_REGEX="Me chamo|muito prazer|qual estilo|que estilo|parte do corpo|qual tua altura|R\\$|fechado por|agendar|pagar sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null and (.conversas[0].dados_coletados.descricao_curta | test("borboleta"; "i")) and (.conversas[0].dados_coletados.estilo | test("fineline"; "i")) and (.conversas[0].dados_coletados.local_corpo | test("perna"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and .conversas[0].dados_coletados.tentativas_foto_local == 1'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "quero uma borboleta fineline na perna, tenho 1.70" and .context_metadata.router_intent == "multi_info" and .context_metadata.router_reason == "multiple_tattoo_fields_detected" and .context_metadata.router_can_mutate_state == true)'
