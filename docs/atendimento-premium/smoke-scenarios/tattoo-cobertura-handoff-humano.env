# Smoke Scenario: tattoo-cobertura-handoff-humano
#
# Objetivo:
# Validar que cobertura/cover-up textual aciona humano sem seguir coleta ou orcamento automatico.

SCENARIO_ID="tattoo-cobertura-handoff-humano"
SCENARIO_TITLE="Tattoo: cobertura textual aciona humano"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="quero cobrir uma tattoo antiga no braco"

EXPECTED_STATE="aguardando_tatuador"
SMOKE_REQUIRE_ORCID="0"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="cobertura|tatuador|avaliar|seguran[cç]a"
FORBIDDEN_BOT_REGEX="or[cç]amento liberado|valor certinho|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|Qual tua altura|parte do corpo|estilo"
FORBIDDEN_TAIL_REGEX="enviar-orcamento-tatuador|pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].orcid == null'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "quero cobrir uma tattoo antiga no braco" and .context_metadata.router_intent == "cobertura" and .context_metadata.tenant_context_layer == "tenant_context_manager" and .context_metadata.tenant_context_aceita_cobertura == true and .context_metadata.tenant_context_gatilhos_handoff_count >= 1)'
