# Smoke Scenario: whatsapp-real-voice-policy-first-contact-image-question
#
# Wave 25 Micro-slice 2 definitivo via Evolution central.

SCENARIO_ID="whatsapp-real-voice-policy-first-contact-image-question"
SCENARIO_TITLE="WhatsApp real: primeiro contato com imagem sem apresentacao mecanica"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="none"
CLEANUP_BEFORE="1"

MESSAGE="o que você viu na imagem?"
EXPECTED_STATE="coletando_tattoo"

EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="Oii, tudo bem\\.|imagem|foto|refer[eê]ncia|desenho|local|corpo|logo|símbolo|simbolo"
FORBIDDEN_BOT_REGEX="Me chamo|muito prazer|foto de novo|não estou vendo uma imagem clara|nao estou vendo uma imagem clara|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|orc_"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null'

SMOKE_MEDIA_MIMETYPE="image/png"
SMOKE_MEDIA_FILE="docs/superpowers/specs/assets/2026-05-04-home-refator-ref/symbols/logo-black-transparent.png"

SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
