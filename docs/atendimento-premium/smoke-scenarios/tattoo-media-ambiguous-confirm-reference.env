# Smoke Scenario: tattoo-media-ambiguous-confirm-reference
#
# Objetivo:
# Validar que a resposta "e referencia" depois de uma foto ambigua preserva a
# imagem em refs_imagens_msg_ids e pede a foto do local.

SCENARIO_ID="tattoo-media-ambiguous-confirm-reference"
SCENARIO_TITLE="Tattoo media: confirmar foto ambigua como referencia"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_tattoo_foto_ambigua_aguardando_confirmacao"
CLEANUP_BEFORE="1"

MESSAGE="é referência do desenho"
EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="refer[eê]ncia|foto do local|local do corpo|onde tu quer tatuar"
FORBIDDEN_BOT_REGEX="nome completo|data de nascimento|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_coletados.foto_local_msg_id == null and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and (.conversas[0].dados_coletados.refs_imagens_msg_ids | length) == 1 and .conversas[0].dados_coletados.tentativas_foto_local == 1 and .conversas[0].dados_coletados.descricao_curta == "rosa" and .conversas[0].dados_coletados.estilo == "fineline" and (.conversas[0].dados_coletados.local_corpo | test("antebraco|antebraço"; "i")) and .conversas[0].dados_coletados.altura_cm == 170 and .conversas[0].orcid == null'
