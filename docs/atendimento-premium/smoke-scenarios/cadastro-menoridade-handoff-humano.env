# Smoke Scenario: cadastro-menoridade-handoff-humano
#
# Objetivo:
# Validar que data de nascimento menor de 18 anos nao segue para orcamento
# automatico. O bot deve parar o fluxo, orientar com seguranca e acionar humano.

SCENARIO_ID="cadastro-menoridade-handoff-humano"
SCENARIO_TITLE="Cadastro: menoridade aciona humano"
SCENARIO_TYPE="http"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="5521970789797"
INSTANCE="inkflow_test_sub4"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"

MESSAGE="12/03/2010"

EXPECTED_STATE="aguardando_tatuador"
EXPECTED_HUMAN_TEXT="$MESSAGE"
EXPECTED_COPY_RISK_MAX="baixo"
EXPECTED_BOT_REGEX="menos de 18|tatuador|seguran[cç]a|respons[aá]vel legal"
FORBIDDEN_BOT_REGEX="or[cç]amento liberado|valor certinho|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o"
FORBIDDEN_TAIL_REGEX="enviar-orcamento-tatuador|pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == "2010-03-12") and (.conversas[0].orcid == null)'
