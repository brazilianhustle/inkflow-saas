# Smoke Scenario: whatsapp-real-cadastro-after-media-nome-data
#
# Objetivo:
# Validar via WhatsApp real multi-turn que, apos midia completa, o cadastro
# aceita nome/data sem perder foto local/referencia nem voltar para tattoo.

SCENARIO_ID="whatsapp-real-cadastro-after-media-nome-data"
SCENARIO_TITLE="WhatsApp real: cadastro pos-midia nome e data"
SCENARIO_TYPE="whatsapp_real_multiturn"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_pos_midia_aguardando_nome"
CLEANUP_BEFORE="1"
STEP_COUNT="2"
STEP_WAIT_SECONDS="4"

MESSAGE_1="Joao Silva"
EXPECTED_STATE_1="coletando_cadastro"
EXPECTED_COPY_RISK_MAX_1="baixo"
EXPECTED_BOT_REGEX_1="data de nascimento"
FORBIDDEN_BOT_REGEX_1="nome completo|foto do local|refer[eê]ncia|tatuador vai avaliar|valor certinho|orc_"
EXPECTED_POLL_JQ_TRUE_1='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == null) and .conversas[0].dados_coletados.foto_local_msg_id == 12632 and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and .conversas[0].dados_coletados.refs_imagens_msg_ids[0] == 11951 and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE_1='. as $logs | any($logs[]; .agent_name == "conversation_router" and .client_input_text == "Joao Silva" and .context_metadata.router_intent == "cadastro_pending_answer" and .context_metadata.router_reason == "pending_nome_completo_answered")'

MESSAGE_2="12/03/1995"
EXPECTED_STATE_2="coletando_cadastro"
EXPECTED_COPY_RISK_MAX_2="medio"
EXPECTED_BOT_REGEX_2="e-?mail|email"
FORBIDDEN_BOT_REGEX_2="Pra liberar teu or[cç]amento|liberar teu or[cç]amento|data de nascimento|foto do local|refer[eê]ncia|tatuador vai avaliar|valor certinho|orc_"
EXPECTED_POLL_JQ_TRUE_2='.conversas[0].dados_cadastro.nome == "Joao Silva" and .conversas[0].dados_cadastro.data_nascimento == "1995-03-12" and .conversas[0].dados_coletados.foto_local_msg_id == 12632 and (.conversas[0].dados_coletados.refs_imagens_msg_ids | type == "array") and .conversas[0].dados_coletados.refs_imagens_msg_ids[0] == 11951 and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE_2='. as $logs | any($logs[]; .agent_name == "conversation_router" and .client_input_text == "12/03/1995" and .context_metadata.router_intent == "cadastro_pending_answer" and .context_metadata.router_reason == "pending_data_nascimento_answered")'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
