# Smoke Scenario: whatsapp-real-lateral-portfolio-indisponivel
#
# Objetivo:
# Validar via WhatsApp real que tenant sem portfolio cadastrado nao aciona
# envio de portfolio e responde com limite honesto.

SCENARIO_ID="whatsapp-real-lateral-portfolio-indisponivel"
SCENARIO_TITLE="WhatsApp real: portfolio indisponivel por tenant"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="tenant_portfolio_indisponivel"
CLEANUP_BEFORE="1"

MESSAGE="tem exemplos de fineline?"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="portfolio|portf[oó]lio|cadastrad|montando|refer|exemplos|trabalhos|posso"
FORBIDDEN_BOT_REGEX="https?://|www\\.|instagram\\.com|mando|te mando|enviei|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|orc_"
FORBIDDEN_TAIL_REGEX="enviar-portfolio|sendMedia falhou|pipeline batch failed|unhandled"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "tem exemplos de fineline?" and .context_metadata.router_intent == "portfolio_requested" and .context_metadata.router_reason == "portfolio_unavailable_for_tenant" and .context_metadata.router_can_mutate_state == false and .context_metadata.tenant_context_layer == "tenant_context_manager" and .context_metadata.tenant_context_portfolio_disponivel == false and .context_metadata.tenant_context_portfolio_urls_count == 0)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
