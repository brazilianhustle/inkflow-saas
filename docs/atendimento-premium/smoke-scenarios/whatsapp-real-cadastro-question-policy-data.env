# Smoke scenario: WhatsApp real usando Evolution central como remetente.

SCENARIO_ID="whatsapp-real-cadastro-question-policy-data"
SCENARIO_TITLE="WhatsApp real: Cadastro QuestionPolicy resolve data de nascimento pendente"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="seed_cadastro_aguardando_data"
CLEANUP_BEFORE="1"

MESSAGE="12/03/1995"
EXPECTED_STATE="coletando_cadastro"

EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="e-?mail|email"
FORBIDDEN_BOT_REGEX="data de nascimento|or[çc]amento.*tatuador|valor certinho"
EXPECTED_POLL_JQ_TRUE='.conversas[0].dados_cadastro.nome == "Joao Silva" and (.conversas[0].dados_cadastro.data_nascimento == "1995-03-12") and (.conversas[0].orcid == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "12/03/1995" and .context_metadata.router_intent == "cadastro_pending_answer" and .context_metadata.router_reason == "pending_data_nascimento_answered" and .context_metadata.router_can_mutate_state == true)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
