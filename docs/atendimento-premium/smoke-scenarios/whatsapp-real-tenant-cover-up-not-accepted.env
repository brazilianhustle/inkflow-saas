# Smoke Scenario: whatsapp-real-tenant-cover-up-not-accepted
#
# Objetivo:
# Validar via WhatsApp real que tenant com aceita_cobertura=false recusa cobertura
# de forma segura, sem acionar LLM, sem handoff/orcamento e com restore automatico.

SCENARIO_ID="whatsapp-real-tenant-cover-up-not-accepted"
SCENARIO_TITLE="WhatsApp real: cobertura nao aceita pelo estudio"
SCENARIO_TYPE="whatsapp_real"

BASE_URL="${BASE_URL:-https://inkflowbrasil.com}"
TENANT_ID="${SMOKE_TENANT_ID:-db686ef2-ca42-43e4-a831-808984d8d6c6}"
PHONE="${SMOKE_SENDER_PHONE:-5521970789797}"
INSTANCE="central"

SETUP="tenant_cobertura_nao_aceita"
CLEANUP_BEFORE="1"

MESSAGE="quero cobrir uma tattoo antiga no braco"

EXPECTED_STATE="coletando_tattoo"
EXPECTED_COPY_RISK_MAX="medio"
EXPECTED_BOT_REGEX="nao faz cobertura|não faz cobertura|tattoo nova|outro local"
FORBIDDEN_BOT_REGEX="acionar|tatuador precisa avaliar|vou acionar|or[cç]amento|R\\$|fechado por|agendar|pagar sinal|link de sinal|pix|cart[aã]o|orc_"
FORBIDDEN_TAIL_REGEX="enviar-orcamento|acionar-handoff|telegram|pipeline batch failed|unhandled|runAgent failed|openai"
EXPECTED_POLL_JQ_TRUE='.conversas[0].estado_agente == "coletando_tattoo" and .conversas[0].orcid == null and ((.conversas[0].dados_coletados.descricao_curta // null) == null)'
EXPECTED_AGENT_LOG_JQ_TRUE='.[] | select(.agent_name == "conversation_router" and .client_input_text == "quero cobrir uma tattoo antiga no braco" and .context_metadata.router_intent == "tenant_cover_up_not_accepted" and .context_metadata.router_reason == "tenant_cover_up_not_accepted" and .context_metadata.router_can_mutate_state == false and .context_metadata.tenant_context_layer == "tenant_context_manager" and .context_metadata.tenant_context_aceita_cobertura == false)'

# Deve vir do ambiente local/secret manager. Nao hardcodar no repo.
SMOKE_BOT_NUMBER="${SMOKE_BOT_NUMBER:-}"
