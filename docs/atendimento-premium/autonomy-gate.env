# Autonomy Gate - Atendimento Premium
#
# Este arquivo controla a janela maxima de execucao sem intervencao humana.
# Promocao de nivel deve ser deliberada: o script pode recomendar, mas nao
# altera CURRENT_LEVEL sozinho.

AUTONOMY_ID="atendimento-premium"
CURRENT_LEVEL="3"
CURRENT_LEVEL_LABEL="mini-campanha de ate 4 micro-slices da mesma familia por rodada"
MAX_BATCH_SIZE="4"

# Baseline operacional usado para contar evidencias recentes.
MIN_PASS_UTC="2026-05-25 07:15"

# Requisitos para recomendar promocao de Level 1 para Level 2.
LEVEL_2_MIN_PASS_SCENARIOS="5"
LEVEL_2_MIN_REAL_WHATSAPP_PASS="2"
LEVEL_2_REQUIRED_SLICE_GATES=$'atendimento-lateral\ncadastro-handoff\nescalation-manager'

# Requisitos para recomendar promocao de Level 2 para Level 3.
# Level 3 nao aumenta por volume bruto sozinho: exige volume, WhatsApp real,
# os slice gates criticos atuais e nenhuma falha/bloqueador ativo.
LEVEL_3_MIN_PASS_SCENARIOS="40"
LEVEL_3_MIN_REAL_WHATSAPP_PASS="18"
LEVEL_3_REQUIRED_SLICE_GATES=$'atendimento-lateral\ncadastro-handoff\nescalation-manager'

# Requisitos para recomendar promocao de Level 3 para Level 4.
# Level 4 so pode ser discutido quando houver volume maior, WhatsApp real
# estavel e documentos explicitos de rollback/staging/loop supervisionado.
LEVEL_4_MIN_PASS_SCENARIOS="70"
LEVEL_4_MIN_REAL_WHATSAPP_PASS="35"
LEVEL_4_REQUIRED_SLICE_GATES=$'atendimento-lateral\ncadastro-handoff\nescalation-manager\nworkflow-manager'
LEVEL_4_REQUIRED_DOCS=$'docs/atendimento-premium/18-rollback-staging-protocol.md\ndocs/atendimento-premium/19-level-4-loop-policy.md'

# Requisitos documentais/operacionais obrigatorios.
REQUIRED_DOCS=$'docs/atendimento-premium/smoke-runs.md\ndocs/atendimento-premium/current-objective.md\ndocs/atendimento-premium/13-smoke-scenario-registry.md\ndocs/atendimento-premium/14-smoke-triage-protocol.md\ndocs/atendimento-premium/16-slice-completion-gate.md'

# Bloqueadores manuais. Manter vazio quando nao houver bloqueio.
# Exemplos: estado_inconsistente, whatsapp_real_fail, risco_financeiro,
# duplicidade_mensagem, deploy_fail, cleanup_risco, decisao_produto_pendente.
BLOCKED_REASONS=""

# Politica atual:
# - Nivel 1 executa somente 1 micro-slice completo.
# - Nivel 2 permite ate 2 micro-slices relacionados na mesma rodada, desde que
#   cada um tenha gate proprio e checkpoint saudavel antes de seguir.
# - Nivel 3 permite mini-campanha de ate 4 micro-slices da mesma familia, ainda com
#   WhatsApp real por micro-slice conversacional e parada em qualquer falha.
# - Level 4 exige staging/rollback/loop supervisionado documentado antes de recomendacao.
# - Mesmo em Level 3, falha em smoke real, deploy, cleanup ou gate volta a
#   execucao para triage antes de qualquer proximo micro-slice.
# - Proxima promocao exige commit deliberado alterando CURRENT_LEVEL.
