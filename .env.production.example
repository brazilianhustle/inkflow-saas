# ─────────────────────────────────────────────────────────────────────────────
# InkFlow — Source of truth pra todas as secrets do CF Pages
# ─────────────────────────────────────────────────────────────────────────────
#
# COMO USAR:
#   1. Copie este arquivo: cp .env.production.example .env.production
#   2. Preencha cada valor (nao commit — .env.production esta gitignored)
#   3. Salve o .env.production no seu password manager (1Password/Bitwarden)
#   4. Rode: bash scripts/sync-secrets.sh
#      → sincroniza TODAS as secrets em production E preview do CF Pages
#
# QUANDO ROTACIONAR ALGUMA:
#   1. Atualize o valor neste arquivo (o seu .env.production local + 1Password)
#   2. Re-rode: bash scripts/sync-secrets.sh
#   3. Pronto — prod + preview sincronizados, sem drift
#
# REGRA DE OURO: nunca seta secret pelo Dashboard CF direto. Sempre via .env + script.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare Pages: webhook secret pro endpoint /api/whatsapp/inbound ──────
WEBHOOK_SECRET=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_KEY=
SUPABASE_PAT=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Evolution API ────────────────────────────────────────────────────────────
EVO_BASE_URL=
EVO_GLOBAL_KEY=
EVO_CENTRAL_APIKEY=
EVO_CENTRAL_INSTANCE=
EVO_DB_CLEANUP_SECRET=

# ── Telegram (admin alerts + tatuador notify) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_USER_ID=
TELEGRAM_WEBHOOK_SECRET=
INKFLOW_TELEGRAM_BOT_TOKEN=
INKFLOW_TELEGRAM_WEBHOOK_SECRET=

# ── Mercado Pago (pagamentos / sinal) ────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── n8n (legacy webhook, removido em Sub-4.2) ────────────────────────────────
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ── Internal secrets (auth entre componentes do InkFlow) ─────────────────────
INKFLOW_TOOL_SECRET=
STUDIO_TOKEN_SECRET=
CLEANUP_SECRET=
CRON_SECRET=
EVAL_SECRET=
KILL_SWITCH_SECRET=
RLS_INTENTIONAL_NO_PUBLIC=

# ── Mailerlite (email marketing) ─────────────────────────────────────────────
MAILERLITE_API_KEY=
MAILERLITE_GROUP_CLIENTES_ATIVOS=
MAILERLITE_GROUP_TRIAL_ATIVO=
MAILERLITE_GROUP_TRIAL_EXPIROU=

# ── Pushover (alerts) ────────────────────────────────────────────────────────
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# ── VPS health check ─────────────────────────────────────────────────────────
VPS_HEALTH_TOKEN=
VPS_HEALTH_URL=

# ── Feature flags ────────────────────────────────────────────────────────────
ENABLE_TRIAL_V2=

# ── GitHub (CI / observability) ──────────────────────────────────────────────
GITHUB_API_TOKEN=
